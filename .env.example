# Search provider API keys (at least one must be set)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
TAVILY_API_KEY=
BRAVE_API_KEY=

# Comma-separated order of search providers (default: google_cse,tavily,brave)
SEARCH_PROVIDER_ORDER=

# Telegram bot credentials (required)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Database path (default: annonces_metropole_lille.sqlite)
DB_PATH=

# Google CSE rate limiting
MAX_CSE_CALLS_PER_DAY=90
SLEEP_BETWEEN_CSE_CALLS=1.2

# Direct URL resolution
RESOLVE_DIRECT_LINKS=1
RESOLVE_TIMEOUT_SEC=10
MAX_RESOLVE_PER_RUN=12

# Catalog page expansion
EXPAND_CATALOG_PAGES=1
MAX_CATALOG_EXPAND_PER_RUN=4
MAX_LINKS_PER_CATALOG_PAGE=8

# Output limits
MAX_ITEMS_PER_RUN_TO_SEND=25
TELEGRAM_MAX_LEN=3500

# Feature flags
ENABLE_FALLBACK_QUERY=1
ENABLE_CONDITIONAL_PAGINATION=1
